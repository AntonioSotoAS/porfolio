---
import "../styles/global.css";
import type { Lang } from "../i18n/ui";

interface Props {
  title?: string;
  description?: string;
  lang?: Lang;
}

const {
  title = "Portafolio | Soluciones digitales con IA",
  description = "Portafolio profesional enfocado en inteligencia artificial, automatización, desarrollo web moderno y soluciones para instituciones.",
  lang = "es",
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>

  <body class="bg-neutral-950 text-neutral-100 antialiased">
    <slot />
  </body>
</html>