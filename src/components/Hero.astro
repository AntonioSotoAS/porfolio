---
interface Props {
  t: any;
}

const { t } = Astro.props;
---

<section class="relative overflow-hidden bg-white dark:bg-neutral-950">
  <div class="absolute inset-0 -z-10">
    <div class="absolute left-1/2 top-0 h-[500px] w-[500px] -translate-x-1/2 rounded-full bg-cyan-500/10 blur-3xl"></div>
    <div class="absolute right-0 top-40 h-[400px] w-[400px] rounded-full bg-violet-500/10 blur-3xl"></div>
  </div>

  <div class="mx-auto flex min-h-screen max-w-6xl flex-col justify-center px-6 pb-24 pt-32">
    <div class="max-w-4xl">
      <p class="mb-5 inline-flex rounded-full border border-cyan-400/20 bg-cyan-400/10 px-4 py-2 text-xs font-medium uppercase tracking-[0.25em] text-cyan-300">
        {t("hero.badge")}
      </p>

      <h1 class="text-5xl font-semibold tracking-tight text-neutral-950 dark:text-white md:text-7xl">
        {t("hero.title")}
      </h1>

      <p class="mt-8 max-w-2xl text-lg leading-8 text-neutral-600 dark:text-neutral-400">
        {t("hero.description")}
      </p>

      <div class="mt-10 flex flex-wrap gap-4">
        <a
          href="#proyectos"
          class="rounded-full bg-neutral-900 px-6 py-3 text-sm font-medium text-white transition hover:bg-neutral-800 dark:bg-white dark:text-neutral-950 dark:hover:bg-neutral-200"
        >
          {t("hero.projects")}
        </a>

        <a
          href="#contacto"
          class="rounded-full border border-neutral-300 px-6 py-3 text-sm font-medium text-neutral-700 transition hover:border-neutral-400 dark:border-neutral-700 dark:text-neutral-200 dark:hover:border-neutral-500"
        >
          {t("hero.contact")}
        </a>
      </div>
    </div>

    <div class="mt-20 grid gap-4 md:grid-cols-3">
      <div class="rounded-3xl border border-neutral-200 bg-neutral-50 p-6 dark:border-white/10 dark:bg-white/[0.03]">
        <p class="text-3xl font-semibold text-neutral-950 dark:text-white">{t("hero.card.ai.title")}</p>
        <p class="mt-3 text-sm leading-6 text-neutral-600 dark:text-neutral-400">
          {t("hero.card.ai.description")}
        </p>
      </div>

      <div class="rounded-3xl border border-neutral-200 bg-neutral-50 p-6 dark:border-white/10 dark:bg-white/[0.03]">
        <p class="text-3xl font-semibold text-neutral-950 dark:text-white">{t("hero.card.web.title")}</p>
        <p class="mt-3 text-sm leading-6 text-neutral-600 dark:text-neutral-400">
          {t("hero.card.web.description")}
        </p>
      </div>

      <div class="rounded-3xl border border-neutral-200 bg-neutral-50 p-6 dark:border-white/10 dark:bg-white/[0.03]">
        <p class="text-3xl font-semibold text-neutral-950 dark:text-white">{t("hero.card.automation.title")}</p>
        <p class="mt-3 text-sm leading-6 text-neutral-600 dark:text-neutral-400">
          {t("hero.card.automation.description")}
        </p>
      </div>
    </div>
  </div>
</section>