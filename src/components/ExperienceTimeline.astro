---
import { experiences } from "../data/experience";
import type { Lang } from "../i18n/ui";
import { getTechIcon } from "../data/stack";

interface Props {
  lang: Lang;
  t: any;
}

const { lang, t } = Astro.props;
---

<section id="experiencia" class="reveal border-t border-neutral-200 bg-white px-6 py-28 dark:border-white/10 dark:bg-neutral-950">
  <div class="mx-auto max-w-6xl">
    <div class="mb-16 max-w-3xl">
      <p class="text-sm font-medium uppercase tracking-[0.3em] text-cyan-600 dark:text-cyan-400">
        {t("experience.badge")}
      </p>

      <h2 class="mt-4 text-3xl font-semibold tracking-tight text-neutral-950 dark:text-white md:text-5xl">
        {t("experience.title")}
      </h2>

      <p class="mt-6 text-base leading-8 text-neutral-600 dark:text-neutral-400">
        {t("experience.description")}
      </p>
    </div>

    <div class="relative">
      <div class="absolute left-4 top-0 hidden h-full w-px bg-gradient-to-b from-cyan-400/70 via-neutral-200 dark:via-white/20 to-transparent md:block"></div>

      <div class="space-y-16">
        {
          experiences.map((item) => (
            <article class="relative grid gap-8 md:grid-cols-[0.9fr_1.4fr] md:pl-16">
              <div class="hidden md:block">
                {item.logo ? (
                  <div class="absolute left-[-4px] top-2 flex h-10 w-10 items-center justify-center rounded-full border border-neutral-200 bg-white p-1.5 shadow-[0_0_20px_rgba(0,0,0,0.05)] dark:border-white/10 dark:bg-neutral-900 dark:shadow-[0_0_20px_rgba(255,255,255,0.02)] transition-transform duration-300 hover:scale-110">
                    <img src={item.logo} alt={item.company} class="max-h-full max-w-full object-contain rounded-full" />
                  </div>
                ) : (
                  <div class="absolute left-[9px] top-2 h-4 w-4 rounded-full bg-cyan-400 shadow-[0_0_30px_rgba(34,211,238,0.8)]" />
                )}
              </div>

              <div>
                <p class="text-2xl font-semibold tracking-tight text-cyan-600 dark:text-cyan-300">
                  {item.role[lang]}
                </p>

                <div class="mt-2 flex items-center gap-3">
                  {item.logo && (
                    <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg border border-neutral-200 bg-white p-1 dark:border-white/10 dark:bg-neutral-900 md:hidden">
                      <img src={item.logo} alt={item.company} class="max-h-full max-w-full object-contain" />
                    </div>
                  )}
                  <h3 class="text-3xl font-semibold text-neutral-950 dark:text-white">
                    {item.company}
                  </h3>
                </div>

                <p class="mt-3 text-sm font-medium text-neutral-500 dark:text-neutral-400">
                  {item.period[lang]}
                </p>

                <div class="mt-5 flex flex-wrap gap-2">
                  {
                    item.tags.map((tag) => {
                      const iconClass = getTechIcon(tag);
                      return (
                        <span class="inline-flex items-center gap-1.5 rounded-full border border-neutral-200 bg-neutral-50/50 px-3 py-1 text-xs text-neutral-600 dark:border-white/10 dark:bg-white/[0.03] dark:text-neutral-300">
                          {iconClass && <i class={`${iconClass} text-[13px]`} />}
                          <span>{tag}</span>
                        </span>
                      );
                    })
                  }
                </div>
              </div>

              <div class="rounded-[2rem] border border-neutral-200 bg-neutral-50/50 p-6 transition-all duration-300 hover:-translate-y-2 hover:shadow-xl hover:border-cyan-400/30 hover:bg-neutral-100/50 dark:border-white/10 dark:bg-white/[0.03] dark:hover:bg-white/[0.05] dark:hover:shadow-cyan-500/10 md:p-8">
                <p class="text-base leading-8 text-neutral-700 dark:text-neutral-300">
                  {item.description[lang]}
                </p>

                <ul class="mt-6 space-y-4">
                  {item.highlights[lang].map((highlight) => (
                    <li class="flex gap-3 text-sm leading-7 text-neutral-600 dark:text-neutral-400">
                      <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-cyan-500 dark:bg-cyan-400"></span>
                      <span>{highlight}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>