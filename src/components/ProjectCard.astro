---
import type { Project } from "../data/projects";
import type { Lang } from "../i18n/ui";
import { getTechIcon } from "../data/stack";

interface Props {
  project: Project;
  lang: Lang;
}

const { project, lang } = Astro.props;
---

<article class="group overflow-hidden rounded-[2rem] border border-neutral-200 bg-neutral-50/50 transition-all duration-300 hover:-translate-y-2 hover:shadow-xl hover:border-cyan-400/40 hover:bg-neutral-100/50 dark:border-white/10 dark:bg-white/[0.03] dark:hover:bg-white/[0.05] dark:hover:shadow-cyan-500/10">
  <div class="relative aspect-[16/10] overflow-hidden bg-neutral-900">
    <!-- Portada con Imagen real de fondo -->
    {project.image && (
      <img
        src={project.image}
        alt={project.title[lang]}
        class="absolute inset-0 h-full w-full object-cover opacity-40 transition-all duration-500 group-hover:scale-105 group-hover:opacity-20"
        onerror="this.remove()"
      />
    )}

    <!-- Video en Hover opcional -->
    {project.video && (
      <video
        src={project.video}
        loop
        muted
        playsinline
        class="project-card-video absolute inset-0 h-full w-full object-cover opacity-0 transition-opacity duration-500 group-hover:opacity-80"
      />
    )}

    <div class="absolute inset-0 bg-gradient-to-br from-cyan-500/20 via-violet-500/10 to-neutral-950/80 transition-all duration-500 group-hover:from-cyan-500/10 group-hover:via-violet-500/5 group-hover:to-neutral-950/90"></div>

    <div class="absolute inset-0 flex items-center justify-center px-6 text-center">
      <div>
        <p class="text-xs font-medium uppercase tracking-[0.3em] text-cyan-300">
          {project.category[lang]}
        </p>
        <h3 class="mt-4 text-3xl font-semibold text-white drop-shadow-md">
          {project.title[lang]}
        </h3>
      </div>
    </div>

    <!-- Indicador de video en la esquina superior derecha -->
    {project.video && (
      <div class="absolute right-5 top-5 flex items-center gap-1.5 rounded-full border border-cyan-400/20 bg-cyan-950/60 px-2.5 py-1 text-[10px] font-semibold text-cyan-300 backdrop-blur transition-opacity duration-300 group-hover:opacity-0">
        <svg class="h-3 w-3 animate-pulse" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <span>VIDEO</span>
      </div>
    )}

    <div class="absolute left-5 top-5 rounded-full border border-white/10 bg-neutral-950/60 px-3 py-1 text-xs text-neutral-300 backdrop-blur">
      {project.year}
    </div>
  </div>

  <div class="p-6">
    <div class="mb-4 flex items-center justify-between gap-4">
      <span class="rounded-full border border-cyan-200 bg-cyan-50 px-3 py-1 text-xs text-cyan-700 dark:border-cyan-400/20 dark:bg-cyan-400/10 dark:text-cyan-300">
        {project.status[lang]}
      </span>
    </div>

    <p class="line-clamp-3 text-sm leading-7 text-neutral-600 dark:text-neutral-400">
      {project.description[lang]}
    </p>

    <div class="mt-6 flex flex-wrap gap-2">
      {
        project.tags.map((tag) => {
          const iconClass = getTechIcon(tag);
          return (
            <span class="inline-flex items-center gap-1.5 rounded-full border border-neutral-200 bg-neutral-100/50 px-3 py-1 text-xs text-neutral-600 dark:border-white/10 dark:bg-white/[0.03] dark:text-neutral-300">
              {iconClass && <i class={`${iconClass} text-[13px]`} />}
              <span>{tag}</span>
            </span>
          );
        })
      }
    </div>

    <div class="mt-6 flex gap-3">
      <button
        data-open-modal={project.id}
        class="cursor-pointer rounded-full bg-neutral-900 px-4 py-2 text-xs font-medium text-white transition hover:bg-neutral-800 dark:bg-white dark:text-neutral-950 dark:hover:bg-neutral-200"
      >
        Ver detalle
      </button>

      {project.github && project.github !== "#" && (
        <a
          href={project.github}
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-full border border-neutral-300 px-4 py-2 text-xs font-medium text-neutral-700 transition hover:border-neutral-400 hover:bg-neutral-50 dark:border-white/10 dark:px-4 dark:py-2 dark:text-neutral-300 dark:hover:border-neutral-400 dark:hover:text-white dark:hover:bg-transparent"
        >
          Código
        </a>
      )}
    </div>
  </div>
</article>