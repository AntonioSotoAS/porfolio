---
import { achievements } from "../data/achievements";
import type { Lang } from "../i18n/ui";

interface Props {
  lang: Lang;
  t: any;
}

const { lang, t } = Astro.props;
---

<section id="logros" class="border-t border-neutral-200 bg-white px-6 py-28 dark:border-white/10 dark:bg-neutral-950">
  <div class="mx-auto max-w-6xl">
    <div class="mb-16 max-w-3xl">
      <p class="text-sm font-medium uppercase tracking-[0.3em] text-cyan-600 dark:text-cyan-400">
        {t("achievements.badge")}
      </p>

      <h2 class="mt-4 text-3xl font-semibold tracking-tight text-neutral-950 dark:text-white md:text-5xl">
        {t("achievements.title")}
      </h2>

      <p class="mt-6 text-base leading-8 text-neutral-600 dark:text-neutral-400">
        {t("achievements.description")}
      </p>
    </div>

    <div class="grid gap-8 md:grid-cols-2">
      {
        achievements.map((item) => (
          <article class="flex flex-col rounded-[2rem] border border-neutral-200 bg-neutral-50/50 p-8 transition hover:border-cyan-400/30 hover:bg-neutral-100/50 dark:border-white/10 dark:bg-white/[0.03] dark:hover:bg-white/[0.05]">
            <div class="mb-4">
              <span class="inline-block rounded-full bg-cyan-100 px-3 py-1 text-xs font-medium text-cyan-800 dark:bg-cyan-900/30 dark:text-cyan-300">
                {item.period[lang]}
              </span>
            </div>
            
            <h3 class="mb-4 text-xl font-semibold text-neutral-950 dark:text-white md:text-2xl">
              {item.title[lang]}
            </h3>
            
            <div class="mb-8 flex-grow space-y-3">
              {item.description[lang].map((desc) => (
                <p class="text-base leading-relaxed text-neutral-600 dark:text-neutral-400">
                  {desc}
                </p>
              ))}
            </div>
            
            <div class="mt-auto flex flex-wrap gap-2">
              {item.tags.map((tag) => (
                <span class="rounded-full border border-neutral-200 bg-white px-3 py-1 text-xs text-neutral-600 dark:border-white/10 dark:bg-white/[0.03] dark:text-neutral-300">
                  {tag}
                </span>
              ))}
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
