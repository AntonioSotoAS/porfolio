---
import ThemeToggle from "./ThemeToggle.astro";
import { languages, type Lang } from "../i18n/ui";

interface Props {
  lang: Lang;
  t: any;
}

const { lang, t } = Astro.props;

const currentPath = Astro.url.pathname;
const pathWithoutLang = currentPath.replace(/^\/(es|en|pt)/, "") || "/";
---

<header
  class="fixed left-0 top-0 z-50 w-full border-b border-neutral-200 bg-white/70 backdrop-blur-xl dark:border-white/10 dark:bg-neutral-950/70"
>
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <a
      href={`/${lang}`}
      class="text-sm font-semibold tracking-tight text-neutral-950 dark:text-white"
    >
      ARTURO ANTONIO MONTEJO SOTO
    </a>

    <nav
      class="hidden items-center gap-8 text-sm text-neutral-500 dark:text-neutral-400 md:flex"
    >
      <a
        href="#sobre-mi"
        class="transition hover:text-neutral-950 dark:hover:text-white"
        >{t("nav.about")}
      </a>
      <a
        href="#proyectos"
        class="transition hover:text-neutral-950 dark:hover:text-white"
        >{t("nav.projects")}
      </a>
      <a
        href="#stack"
        class="transition hover:text-neutral-950 dark:hover:text-white"
        >{t("nav.stack")}
      </a>
      <a
        href="#contacto"
        class="transition hover:text-neutral-950 dark:hover:text-white"
        >{t("nav.contact")}
      </a>
    </nav>

    <div class="flex items-center gap-3">
      <ThemeToggle />
      <div
        class="flex rounded-full border border-neutral-200 bg-neutral-50 p-1 dark:border-white/10 dark:bg-white/[0.03]"
      >
        {
          Object.entries(languages).map(([code, label]) => (
            <a
              href={`/${code}${pathWithoutLang === "/" ? "" : pathWithoutLang}`}
              class={`rounded-full px-3 py-1 text-xs transition ${
                code === lang
                  ? "bg-white text-neutral-950 shadow-sm dark:bg-white dark:text-neutral-950"
                  : "text-neutral-500 hover:text-neutral-950 dark:text-neutral-400 dark:hover:text-white"
              }`}
              aria-label={`Cambiar idioma a ${label}`}
            >
              {code.toUpperCase()}
            </a>
          ))
        }
      </div>

      <a
        href="#contacto"
        class="hidden rounded-full border border-neutral-200 px-4 py-2 text-sm text-neutral-700 transition hover:border-cyan-500/50 hover:text-cyan-600 dark:border-white/10 dark:text-neutral-200 dark:hover:border-cyan-400/50 dark:hover:text-white sm:inline-flex"
      >
        {t("nav.cta")}
      </a>
    </div>
  </div>
</header>
