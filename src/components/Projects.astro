---
import ProjectCard from "./ProjectCard.astro";
import { projects } from "../data/projects";
import type { Lang } from "../i18n/ui";
import { getTechIcon } from "../data/stack";

interface Props {
  lang: Lang;
  t: any;
}

const { lang, t } = Astro.props;
---

<section id="proyectos" class="reveal border-t border-neutral-200 bg-white px-6 py-28 dark:border-white/10 dark:bg-neutral-950">
  <div class="mx-auto max-w-6xl">
    <div class="mb-12 max-w-3xl">
      <p class="text-sm font-medium uppercase tracking-[0.3em] text-cyan-600 dark:text-cyan-400">
        {t("projects.badge")}
      </p>

      <h2 class="mt-4 text-3xl font-semibold tracking-tight text-neutral-950 dark:text-white md:text-5xl">
        {t("projects.title")}
      </h2>

      <p class="mt-6 text-base leading-8 text-neutral-600 dark:text-neutral-400">
        {t("projects.description")}
      </p>
    </div>

    <!-- Grid de Proyectos -->
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {
        projects.map((project) => (
          <ProjectCard project={project} lang={lang} />
        ))
      }
    </div>
  </div>
</section>

<!-- Modales de Proyectos -->
{
  projects.map((project) => {
    const desc = project.longDescription ? project.longDescription[lang] : project.description[lang];
    const feats = project.features ? project.features[lang] : [];
    const gallery = project.gallery && project.gallery.length > 0 ? project.gallery : (project.image ? [project.image] : []);

    return (
      <div
        id={`modal-${project.id}`}
        class="project-modal fixed inset-0 z-50 flex items-center justify-center p-0 md:p-6 opacity-0 pointer-events-none transition-all duration-300"
        role="dialog"
        aria-modal="true"
      >
        <!-- Backdrop (Fondo oscuro con desenfoque) -->
        <div class="modal-backdrop absolute inset-0 bg-neutral-950/80 backdrop-blur-xl" />

        <!-- Botón de Cierre de Escritorio Pinned (Solo visible en pantallas medianas y grandes) -->
        <button
          class="close-modal-btn cursor-pointer absolute right-8 top-8 z-50 hidden rounded-full border border-neutral-200 bg-white/90 p-2.5 text-neutral-500 shadow-md backdrop-blur transition-all duration-300 hover:rotate-90 hover:bg-white hover:text-neutral-900 dark:border-white/10 dark:bg-neutral-800/90 dark:text-neutral-400 dark:hover:bg-neutral-700 dark:hover:text-white md:flex"
          aria-label={t("projects.modal.close")}
        >
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>

        <!-- Tarjeta de contenido del modal (Pantalla completa nativa en móvil con slide-up, tarjeta flotante centrada en desktop) -->
        <div class="modal-content relative w-full h-full max-h-[100dvh] overflow-y-auto bg-white/95 shadow-2xl backdrop-blur-md dark:bg-neutral-900/95 md:max-w-5xl md:max-h-[90vh] md:rounded-[2rem] md:border md:border-neutral-200 md:dark:border-white/10 flex flex-col">
          
          <!-- Cabecera Sticky para Móvil (Solo visible en pantallas pequeñas, incluye safe area e información de cabecera) -->
          <div class="sticky top-0 z-30 flex items-center justify-between border-b border-neutral-100 bg-white/90 px-4 py-3 backdrop-blur-md dark:border-white/5 dark:bg-neutral-900/90 md:hidden pt-[calc(env(safe-area-inset-top,16px)+12px)] pb-3">
            <span class="text-xs font-semibold uppercase tracking-[0.2em] text-cyan-600 dark:text-cyan-400 truncate max-w-[240px]">
              {project.title[lang]}
            </span>
            <button
              class="close-modal-btn cursor-pointer rounded-full bg-neutral-100 p-2 text-neutral-500 hover:bg-neutral-200 active:scale-95 transition-all dark:bg-neutral-800 dark:text-neutral-400 dark:hover:bg-neutral-700"
              aria-label={t("projects.modal.close")}
            >
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </div>

          <!-- Contenedor del contenido del proyecto -->
          <div class="p-5 sm:p-6 md:p-10 flex flex-col md:grid md:grid-cols-[1.1fr_0.9fr] gap-8 md:gap-12 w-full">

          <!-- Columna Multimedia (Izquierda) -->
          <div class="flex flex-col gap-6">
            <!-- Video Demostrativo si está disponible -->
            {project.video && (
              <div class="flex flex-col gap-2">
                <span class="text-xs font-semibold uppercase tracking-[0.2em] text-cyan-600 dark:text-cyan-400">
                  {t("projects.modal.video")}
                </span>
                <div class="video-container-wrapper relative overflow-hidden rounded-2xl border border-neutral-200 bg-neutral-950 shadow-md dark:border-white/10 aspect-video group/video">
                  <video
                    src={project.video}
                    controls
                    preload="metadata"
                    class="h-full w-full object-contain"
                  />
                  <!-- Botón Expandir Video -->
                  <button
                    class="expand-video-btn cursor-pointer absolute right-3 top-3 z-10 rounded-full bg-neutral-950/50 p-2 text-white opacity-0 group-hover/video:opacity-100 backdrop-blur transition-all duration-300 hover:bg-neutral-950/70 hover:scale-105 active:scale-95"
                    aria-label="Expand video"
                  >
                    <svg class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M20.25 3.75v4.5m0-4.5h-4.5m4.5 0L15 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 20.25v-4.5m0 4.5h-4.5m4.5 0l-6-6" />
                    </svg>
                  </button>
                </div>
              </div>
            )}

            <!-- Carrusel de Capturas si está disponible -->
            {gallery && gallery.length > 0 && (
              <div class="flex flex-col gap-2">
                <span class="text-xs font-semibold uppercase tracking-[0.2em] text-cyan-600 dark:text-cyan-400">
                  {t("projects.modal.gallery")}
                </span>
                
                <div class="project-carousel relative aspect-[16/10] overflow-hidden rounded-2xl border border-neutral-200 bg-neutral-950 dark:border-white/10 group/carousel" data-current-index="0">
                  <!-- Botón Expandir Imagen -->
                  <button
                    class="expand-carousel-btn cursor-pointer absolute right-3 top-3 z-10 rounded-full bg-neutral-950/50 p-2 text-white opacity-0 group-hover/carousel:opacity-100 backdrop-blur transition-all duration-300 hover:bg-neutral-950/70 hover:scale-105 active:scale-95"
                    aria-label="Expand image"
                  >
                    <svg class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v6m3-3H7" />
                    </svg>
                  </button>

                  <!-- Imágenes del carrusel -->
                  <div class="carousel-slides absolute inset-0 cursor-zoom-in">
                    {gallery.map((imgUrl, idx) => (
                      <img
                        src={imgUrl}
                        alt={`${project.title[lang]} - Screenshot ${idx + 1}`}
                        class={`carousel-slide absolute inset-0 h-full w-full object-cover transition-all duration-500 ${
                          idx === 0 ? "opacity-100 scale-100" : "opacity-0 scale-95 pointer-events-none"
                        }`}
                      />
                    ))}
                  </div>

                  <!-- Degradado de fondo para legibilidad de controles -->
                  <div class="absolute inset-x-0 bottom-0 h-16 bg-gradient-to-t from-neutral-950/60 to-transparent pointer-events-none"></div>

                  <!-- Botones de Control (Solo si hay más de 1 imagen) -->
                  {gallery.length > 1 && (
                    <>
                      <button
                        class="prev-slide-btn cursor-pointer absolute left-3 top-1/2 -translate-y-1/2 rounded-full bg-neutral-950/40 p-2 text-white backdrop-blur transition hover:bg-neutral-950/60 active:scale-95 z-10"
                        aria-label="Previous image"
                      >
                        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
                        </svg>
                      </button>

                      <button
                        class="next-slide-btn cursor-pointer absolute right-3 top-1/2 -translate-y-1/2 rounded-full bg-neutral-950/40 p-2 text-white backdrop-blur transition hover:bg-neutral-950/60 active:scale-95 z-10"
                        aria-label="Next image"
                      >
                        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                        </svg>
                      </button>

                      <!-- Indicadores de puntos (Bullets) -->
                      <div class="absolute bottom-3 left-1/2 flex -translate-x-1/2 gap-1.5 z-10">
                        {gallery.map((_, idx) => (
                          <button
                            class={`carousel-bullet cursor-pointer h-2 w-2 rounded-full transition-all duration-300 ${
                              idx === 0 ? "bg-white w-4" : "bg-white/40"
                            }`}
                            data-index={idx}
                            aria-label={`Go to slide ${idx + 1}`}
                          />
                        ))}
                      </div>
                    </>
                  )}
                </div>
              </div>
            )}
          </div>

          <!-- Columna Información (Derecha) -->
          <div class="flex flex-col justify-between pt-4 md:pt-0">
            <div>
              <!-- Categoría y Año -->
              <div class="flex items-center gap-3">
                <span class="text-xs font-semibold uppercase tracking-[0.25em] text-cyan-600 dark:text-cyan-400">
                  {project.category[lang]}
                </span>
                <span class="text-xs text-neutral-400 dark:text-neutral-500">•</span>
                <span class="text-xs font-medium text-neutral-500 dark:text-neutral-400">
                  {project.year}
                </span>
              </div>

              <!-- Título principal -->
              <h3 class="mt-3 text-3xl font-bold tracking-tight text-neutral-950 dark:text-white md:text-4xl">
                {project.title[lang]}
              </h3>

              <!-- Estado -->
              <div class="mt-3 flex">
                <span class="rounded-full border border-cyan-200 bg-cyan-50 px-3 py-1 text-xs font-medium text-cyan-700 dark:border-cyan-400/20 dark:bg-cyan-400/10 dark:text-cyan-300">
                  {project.status[lang]}
                </span>
              </div>

              <!-- Descripción -->
              <p class="mt-6 text-sm leading-8 text-neutral-600 dark:text-neutral-300">
                {desc}
              </p>

              <!-- Características Clave (si existen) -->
              {feats && feats.length > 0 && (
                <div class="mt-6">
                  <h4 class="text-xs font-semibold uppercase tracking-[0.2em] text-cyan-600 dark:text-cyan-400">
                    {t("projects.modal.features")}
                  </h4>
                  <ul class="mt-3 space-y-2">
                    {feats.map((feat) => (
                      <li class="flex items-start gap-2.5 text-sm leading-6 text-neutral-600 dark:text-neutral-300">
                        <svg class="mt-1 h-4 w-4 shrink-0 text-cyan-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                        </svg>
                        <span>{feat}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              )}
            </div>

            <!-- Tecnologías y Enlaces -->
            <div class="mt-8 border-t border-neutral-100 pt-6 dark:border-white/10">
              <h4 class="text-xs font-semibold uppercase tracking-[0.2em] text-neutral-500 dark:text-neutral-400">
                {t("projects.modal.tech")}
              </h4>
              <div class="mt-3 flex flex-wrap gap-2">
                {project.tags.map((tag) => {
                  const iconClass = getTechIcon(tag);
                  return (
                    <span class="inline-flex items-center gap-1.5 rounded-full border border-neutral-200 bg-neutral-100/50 px-3 py-1 text-xs text-neutral-600 dark:border-white/10 dark:bg-white/[0.03] dark:text-neutral-300">
                      {iconClass && <i class={`${iconClass} text-[13px]`} />}
                      <span>{tag}</span>
                    </span>
                  );
                })}
              </div>

              <!-- Botones de Enlace -->
              <div class="mt-8 flex flex-wrap gap-3">
                {project.github && project.github !== "#" && (
                  <a
                    href={project.github}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center gap-2 rounded-full bg-neutral-900 px-5 py-2.5 text-xs font-medium text-white transition hover:bg-neutral-800 dark:bg-white dark:text-neutral-950 dark:hover:bg-neutral-200"
                  >
                    <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                      <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.87 8.17 6.84 9.5.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34-.46-1.16-1.11-1.47-1.11-1.47-.9-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.9 1.52 2.34 1.07 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.92 0-1.11.38-2 1.03-2.71-.1-.25-.45-1.29.1-2.64 0 0 .84-.27 2.75 1.02.79-.22 1.65-.33 2.5-.33.85 0 1.71.11 2.5.33 1.91-1.29 2.75-1.02 2.75-1.02.55 1.35.2 2.39.1 2.64.65.71 1.03 1.6 1.03 2.71 0 3.82-2.34 4.66-4.57 4.91.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0012 2z"/>
                    </svg>
                    <span>{t("projects.modal.code")}</span>
                  </a>
                )}

                {project.href && project.href !== "#" && (
                  <a
                    href={project.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center gap-2 rounded-full border border-neutral-300 px-5 py-2.5 text-xs font-medium text-neutral-700 transition hover:border-neutral-400 hover:bg-neutral-50 dark:border-white/10 dark:text-neutral-300 dark:hover:border-neutral-400 dark:hover:text-white"
                  >
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                    </svg>
                    <span>{project.demoLabel ? project.demoLabel[lang] : t("projects.modal.demo")}</span>
                  </a>
                )}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    );
  })
}

<!-- Lightbox Global para ver multimedia en pantalla completa -->
<div
  id="media-lightbox"
  class="media-lightbox fixed inset-0 z-[100] flex items-center justify-center bg-neutral-950/95 backdrop-blur-2xl opacity-0 pointer-events-none transition-all duration-300"
  role="dialog"
  aria-modal="true"
>
  <!-- Backdrop de cierre -->
  <div class="lightbox-backdrop absolute inset-0 cursor-zoom-out"></div>

  <!-- Botón de Cerrar -->
  <button
    id="close-lightbox-btn"
    class="cursor-pointer absolute right-6 top-6 z-10 rounded-full border border-white/10 bg-white/5 p-3 text-white backdrop-blur transition-all duration-300 hover:rotate-90 hover:bg-white/15 active:scale-95"
    aria-label="Close fullscreen"
  >
    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>

  <!-- Botones de Navegación del Lightbox (Solo para imágenes) -->
  <button
    id="prev-lightbox-btn"
    class="cursor-pointer absolute left-6 top-1/2 -translate-y-1/2 rounded-full border border-white/10 bg-white/5 p-3 text-white backdrop-blur transition hover:bg-white/15 active:scale-95 z-10"
    aria-label="Previous image"
  >
    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
    </svg>
  </button>

  <button
    id="next-lightbox-btn"
    class="cursor-pointer absolute right-6 top-1/2 -translate-y-1/2 rounded-full border border-white/10 bg-white/5 p-3 text-white backdrop-blur transition hover:bg-white/15 active:scale-95 z-10"
    aria-label="Next image"
  >
    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
    </svg>
  </button>

  <!-- Contenedor del Contenido Expandido -->
  <div id="lightbox-content-wrapper" class="relative max-w-[90vw] max-h-[85vh] flex items-center justify-center transition-all duration-300 scale-95 opacity-0">
    <img id="lightbox-img" class="hidden max-w-full max-h-[85vh] object-contain rounded-2xl shadow-2xl border border-white/10" src="" alt="" />
    <video id="lightbox-video" class="hidden max-w-full max-h-[85vh] object-contain rounded-2xl shadow-2xl border border-white/10" controls src=""></video>
  </div>
</div>

<style>
  /* Estilos para el modal interactivo */
  .project-modal {
    transition: opacity 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  
  .project-modal.active {
    opacity: 1;
    pointer-events: auto;
  }
  
  .project-modal.active .modal-content {
    transform: translateY(0) scale(1) !important;
    opacity: 1 !important;
  }

  .modal-content {
    /* Estado inicial inactivo en móvil (completamente abajo y transparente) */
    transform: translateY(100%) scale(1);
    opacity: 0;
    transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1), opacity 0.3s ease;
  }

  @media (min-width: 768px) {
    .modal-content {
      /* Estado inicial inactivo en desktop (ligeramente abajo y menor escala) */
      transform: translateY(2rem) scale(0.95);
    }
  }

  /* Ocultar barra de scroll en el modal */
  .modal-content::-webkit-scrollbar {
    width: 6px;
  }
  .modal-content::-webkit-scrollbar-track {
    background: transparent;
  }
  .modal-content::-webkit-scrollbar-thumb {
    background: rgba(156, 163, 175, 0.2);
    border-radius: 9999px;
  }
  .modal-content::-webkit-scrollbar-thumb:hover {
    background: rgba(156, 163, 175, 0.4);
  }

  /* Estilos para el Lightbox Global */
  .media-lightbox {
    transition: opacity 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .media-lightbox.active {
    opacity: 1;
    pointer-events: auto;
  }
  .media-lightbox.active #lightbox-content-wrapper {
    transform: scale(1);
    opacity: 1;
  }
</style>

<script>
  // Script para manejar previsualización de videos e interactividad de los modales y lightbox en el cliente
  const initProjectInteractions = () => {
    // 1. Control de Hover de Video en las Tarjetas (Desktop)
    const cards = document.querySelectorAll("article.group");
    cards.forEach((card) => {
      const video = card.querySelector(".project-card-video") as HTMLVideoElement;
      if (video) {
        card.addEventListener("mouseenter", () => {
          video.play().catch(() => {});
        });
        card.addEventListener("mouseleave", () => {
          video.pause();
          video.currentTime = 0;
        });
      }
    });

    // 2. Control de Apertura de Modales
    const openBtns = document.querySelectorAll("[data-open-modal]");
    openBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const projectId = btn.getAttribute("data-open-modal");
        const modal = document.getElementById(`modal-${projectId}`);
        if (modal) {
          modal.classList.add("active");
          document.body.style.overflow = "hidden"; // Desactivar scroll en body

          // Asegurar que el modal se abra desde el inicio del scroll
          const modalContent = modal.querySelector(".modal-content");
          if (modalContent) {
            modalContent.scrollTop = 0;
          }

          // Si el modal tiene un video principal, reiniciarlo y cargarlo
          const modalVideo = modal.querySelector("video") as HTMLVideoElement;
          if (modalVideo) {
            modalVideo.currentTime = 0;
          }
        }
      });
    });

    // 3. Control de Cierre de Modales
    const closeModal = (modal: Element) => {
      modal.classList.remove("active");
      document.body.style.overflow = ""; // Restaurar scroll

      // Pausar todos los videos dentro del modal
      const modalVideos = modal.querySelectorAll("video");
      modalVideos.forEach((v) => {
        v.pause();
      });
    };

    const closeBtns = document.querySelectorAll(".close-modal-btn");
    closeBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const modal = btn.closest(".project-modal");
        if (modal) closeModal(modal);
      });
    });

    const backdrops = document.querySelectorAll(".modal-backdrop");
    backdrops.forEach((backdrop) => {
      backdrop.addEventListener("click", () => {
        const modal = backdrop.closest(".project-modal");
        if (modal) closeModal(modal);
      });
    });

    // Cierre por tecla Escape
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") {
        const activeLightbox = document.getElementById("media-lightbox");
        if (activeLightbox && activeLightbox.classList.contains("active")) {
          closeLightbox();
        } else {
          const activeModal = document.querySelector(".project-modal.active");
          if (activeModal) closeModal(activeModal);
        }
      }
    });

    // 4. Control de Carruseles de Imágenes
    const carousels = document.querySelectorAll(".project-carousel");
    carousels.forEach((carousel) => {
      const slides = carousel.querySelectorAll(".carousel-slide");
      const bullets = carousel.querySelectorAll(".carousel-bullet");
      const prevBtn = carousel.querySelector(".prev-slide-btn");
      const nextBtn = carousel.querySelector(".next-slide-btn");
      let currentIndex = 0;

      const updateCarousel = (index: number) => {
        const total = slides.length;
        if (index < 0) index = total - 1;
        if (index >= total) index = 0;
        currentIndex = index;

        // Actualizar index en el contenedor
        carousel.setAttribute("data-current-index", currentIndex.toString());

        // Actualizar visibilidad de slides con animación suave
        slides.forEach((slide, idx) => {
          if (idx === currentIndex) {
            slide.classList.remove("opacity-0", "scale-95", "pointer-events-none");
            slide.classList.add("opacity-100", "scale-100");
          } else {
            slide.classList.add("opacity-0", "scale-95", "pointer-events-none");
            slide.classList.remove("opacity-100", "scale-100");
          }
        });

        // Actualizar bullets (puntos indicadores)
        bullets.forEach((bullet, idx) => {
          if (idx === currentIndex) {
            bullet.classList.add("bg-white", "w-4");
            bullet.classList.remove("bg-white/40");
          } else {
            bullet.classList.remove("bg-white", "w-4");
            bullet.classList.add("bg-white/40");
          }
        });
      };

      if (prevBtn) {
        prevBtn.addEventListener("click", (e) => {
          e.stopPropagation();
          updateCarousel(currentIndex - 1);
        });
      }

      if (nextBtn) {
        nextBtn.addEventListener("click", (e) => {
          e.stopPropagation();
          updateCarousel(currentIndex + 1);
        });
      }

      bullets.forEach((bullet) => {
        bullet.addEventListener("click", (e) => {
          e.stopPropagation();
          const targetIndex = parseInt(bullet.getAttribute("data-index") || "0");
          updateCarousel(targetIndex);
        });
      });
    });

    // 5. Lógica del Lightbox Global de Pantalla Completa
    const lightbox = document.getElementById("media-lightbox") as HTMLDivElement;
    const lightboxImg = document.getElementById("lightbox-img") as HTMLImageElement;
    const lightboxVideo = document.getElementById("lightbox-video") as HTMLVideoElement;
    const closeLightboxBtn = document.getElementById("close-lightbox-btn") as HTMLButtonElement;
    const lightboxBackdrop = lightbox?.querySelector(".lightbox-backdrop") as HTMLDivElement;
    const prevLightboxBtn = document.getElementById("prev-lightbox-btn") as HTMLButtonElement;
    const nextLightboxBtn = document.getElementById("next-lightbox-btn") as HTMLButtonElement;

    let activeGallery: string[] = [];
    let activeGalleryIndex = 0;

    const openLightboxImage = (images: string[], index: number) => {
      activeGallery = images;
      activeGalleryIndex = index;

      lightboxImg.src = activeGallery[activeGalleryIndex];
      lightboxImg.classList.remove("hidden");
      lightboxVideo.classList.add("hidden");
      lightboxVideo.src = "";

      // Mostrar u ocultar botones de navegación del lightbox según cantidad de imágenes
      if (activeGallery.length > 1) {
        prevLightboxBtn.classList.remove("hidden");
        nextLightboxBtn.classList.remove("hidden");
      } else {
        prevLightboxBtn.classList.add("hidden");
        nextLightboxBtn.classList.add("hidden");
      }

      lightbox.classList.add("active");
    };

    const openLightboxVideo = (videoSrc: string) => {
      activeGallery = [];
      activeGalleryIndex = 0;

      lightboxVideo.src = videoSrc;
      lightboxVideo.classList.remove("hidden");
      lightboxImg.classList.add("hidden");
      lightboxImg.src = "";

      prevLightboxBtn.classList.add("hidden");
      nextLightboxBtn.classList.add("hidden");

      lightbox.classList.add("active");
      lightboxVideo.play().catch(() => {});
    };

    const closeLightbox = () => {
      lightbox.classList.remove("active");
      lightboxVideo.pause();
      lightboxVideo.src = "";
      lightboxImg.src = "";
    };

    // Registrar clicks en imágenes de carrusel (tanto la imagen como el botón expandir)
    document.querySelectorAll(".project-carousel").forEach((carousel) => {
      const slides = carousel.querySelectorAll(".carousel-slide") as NodeListOf<HTMLImageElement>;
      const expandBtn = carousel.querySelector(".expand-carousel-btn");
      
      const getGalleryUrls = () => Array.from(slides).map((slide) => slide.src);

      const triggerExpand = () => {
        const currentIndex = parseInt(carousel.getAttribute("data-current-index") || "0");
        const urls = getGalleryUrls();
        if (urls.length > 0) {
          openLightboxImage(urls, currentIndex);
        }
      };

      expandBtn?.addEventListener("click", (e) => {
        e.stopPropagation();
        triggerExpand();
      });

      carousel.querySelector(".carousel-slides")?.addEventListener("click", (e) => {
        e.stopPropagation();
        triggerExpand();
      });
    });

    // Registrar clicks en videos (botón de expandir)
    document.querySelectorAll(".video-container-wrapper").forEach((container) => {
      const expandBtn = container.querySelector(".expand-video-btn");
      const video = container.querySelector("video") as HTMLVideoElement;

      expandBtn?.addEventListener("click", (e) => {
        e.stopPropagation();
        if (video && video.src) {
          openLightboxVideo(video.src);
        }
      });
    });

    // Controles de navegación del Lightbox
    const updateLightboxImage = (index: number) => {
      if (activeGallery.length === 0) return;
      if (index < 0) index = activeGallery.length - 1;
      if (index >= activeGallery.length) index = 0;
      activeGalleryIndex = index;
      lightboxImg.src = activeGallery[activeGalleryIndex];
    };

    prevLightboxBtn?.addEventListener("click", (e) => {
      e.stopPropagation();
      updateLightboxImage(activeGalleryIndex - 1);
    });

    nextLightboxBtn?.addEventListener("click", (e) => {
      e.stopPropagation();
      updateLightboxImage(activeGalleryIndex + 1);
    });

    // Cierre del Lightbox
    closeLightboxBtn?.addEventListener("click", closeLightbox);
    lightboxBackdrop?.addEventListener("click", closeLightbox);
  };

  // Ejecutar inicialización inmediatamente y en cambios de página (para compatibilidad con transiciones de Astro)
  document.addEventListener("DOMContentLoaded", initProjectInteractions);
  document.addEventListener("astro:page-load", initProjectInteractions);
</script>