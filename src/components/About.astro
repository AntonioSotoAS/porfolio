---
interface Props {
  t: any;
}

const { t } = Astro.props;
---

<section id="sobre-mi" class="reveal border-t border-neutral-200 bg-white px-6 py-28 dark:border-white/10 dark:bg-neutral-950">
  <div class="mx-auto grid max-w-6xl gap-12 md:grid-cols-[0.8fr_1.2fr]">
    <div>
      <p class="text-sm font-medium uppercase tracking-[0.3em] text-cyan-600 dark:text-cyan-400">
        {t("about.badge")}
      </p>

      <h2 class="mt-4 text-3xl font-semibold tracking-tight text-neutral-950 dark:text-white md:text-5xl">
        {t("about.title")}
      </h2>
    </div>

    <div class="space-y-6 text-base leading-8 text-neutral-600 dark:text-neutral-400">
      <p>{t("about.p1")}</p>
      <p>{t("about.p2")}</p>

      <div class="pt-2">
        <a
          href="/cv/MI-CV-2026.pdf"
          download="Arturo_Antonio_Montejo_Soto_CV_2026.pdf"
          class="inline-flex items-center gap-2 rounded-full bg-neutral-900 px-6 py-3 text-sm font-medium text-white transition hover:bg-neutral-800 dark:bg-white dark:text-neutral-950 dark:hover:bg-neutral-200"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-4 w-4"
          >
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
            <polyline points="7 10 12 15 17 10"></polyline>
            <line x1="12" y1="15" x2="12" y2="3"></line>
          </svg>
          {t("about.download_cv")}
        </a>
      </div>

      <div class="grid gap-4 pt-6 sm:grid-cols-3">
        <div class="rounded-3xl border border-neutral-200 bg-neutral-50/50 p-5 dark:border-white/10 dark:bg-white/[0.03]">
          <p class="text-2xl font-semibold text-neutral-950 dark:text-white">2x</p>
          <p class="mt-2 text-sm text-neutral-600 dark:text-neutral-400">{t("about.stat1")}</p>
        </div>

        <div class="rounded-3xl border border-neutral-200 bg-neutral-50/50 p-5 dark:border-white/10 dark:bg-white/[0.03]">
          <p class="text-2xl font-semibold text-neutral-950 dark:text-white">IA</p>
          <p class="mt-2 text-sm text-neutral-600 dark:text-neutral-400">{t("about.stat2")}</p>
        </div>

        <div class="rounded-3xl border border-neutral-200 bg-neutral-50/50 p-5 dark:border-white/10 dark:bg-white/[0.03]">
          <p class="text-2xl font-semibold text-neutral-950 dark:text-white">Full-stack</p>
          <p class="mt-2 text-sm text-neutral-600 dark:text-neutral-400">{t("about.stat3")}</p>
        </div>
      </div>
    </div>
  </div>
</section>